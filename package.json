{
  "name": "uniatlas-bosnia",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "db:migrate_dev": "cd backend && npm run db:migrate_dev",
    "db:reset": "cd backend && npm run db:reset",
    "db:deploy_generate": "cd backend && npm run db:deploy_generate",
    "db:generate": "cd backend && npm run db:generate",
    "db:seed": "cd backend && npm run db:seed",
    "db:test:deploy_generate": "cd backend && npm run db:test:deploy_generate",
    "db:test:seed": "cd backend && npm run db:test:seed",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "test:all": "npm run test:backend -- run && npm run test:frontend -- run",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test",
    "test:coverage:all": "concurrently \"cd backend && npx vitest --coverage run\" \"cd frontend && npx vitest --coverage run\"",
    "test:coverage:backend": "cd backend && npx vitest --coverage",
    "test:coverage:frontend": "cd frontend && npx vitest --coverage",
    "prisma_studio": "cd backend && npm run prisma_studio --",
    "remove_merged": "git branch --merged | grep -Ev '(^\\*|main|master)' | xargs git branch -d && git fetch -p",
    "format:all": "npm run format:backend && npm run format:frontend",
    "format:backend": "cd backend && npm run format",
    "format:frontend": "cd frontend && npm run format",
    "format:check:all": "npm run format:check:backend && npm run format:check:frontend",
    "format:check:backend": "cd backend && npm run format:check",
    "format:check:frontend": "cd frontend && npm run format:check",
    "lint:all": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "typecheck:all": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "cd backend && npm run typecheck",
    "typecheck:frontend": "cd frontend && npm run typecheck",
    "build:all": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goran1010/uniatlas-bosnia.git"
  },
  "keywords": [],
  "author": "Goran Jović",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/goran1010/uniatlas-bosnia/issues"
  },
  "homepage": "https://github.com/goran1010/uniatlas-bosnia#readme",
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
