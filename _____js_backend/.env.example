# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/uniatlas-bosnia
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/test_uniatlas-bosnia

# Email Service Configuration (Resend)
RESEND_API_KEY=replace-with-resend-api-key

# Application Configuration
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
PORT=3000
COOKIE_SECRET=replace-with-cookie-secret

NODE_ENV=development

# GitHub OAuth
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
# Local: http://localhost:3000/auth/github/callback
# Production: https://yoursite.netlify.app/backend/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback