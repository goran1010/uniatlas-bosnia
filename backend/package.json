{
  "name": "uniatlas-bosnia-backend",
  "version": "1.0.0",
  "keywords": [],
  "author": "Goran Jović",
  "license": "AGPL-3.0-only",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "build": "tsc --build && npm run db:deploy_generate",
    "db:deploy_generate": "cd ./src && npx prisma migrate deploy && npx prisma generate",
    "db:generate": "cd ./src && npx prisma generate",
    "db:seed": "cd ./src && npx prisma db seed",
    "db:test:deploy_generate": "NODE_ENV=test cd ./src && npx prisma migrate deploy && NODE_ENV=test cd ./src && npx prisma generate",
    "db:test:seed": "NODE_ENV=test cd ./src && npx prisma db seed",
    "test": "NODE_ENV=test vitest",
    "start": "node --env-file-if-exists=./src/.env dist/index.js",
    "dev": "tsx watch --env-file-if-exists=./src/.env src/index.ts | pino-pretty",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@quixo3/prisma-session-store": "^3.1.21",
    "@types/express-session": "^1.19.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-sync": "^4.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "resend": "^6.12.4"
  }
}
