{
  "name": "uniatlas-bosnia-backend",
  "version": "1.0.0",
  "description": "REST API backend for UniAtlas Bosnia - providing open data about Bosnia and Herzegovina",
  "main": "index.js",
  "engines": {
    "node": "24.x"
  },
  "prisma": {
    "seed": "node db/seed.js"
  },
  "scripts": {
    "build": "npx prisma generate && npx prisma migrate deploy",
    "test": "NODE_ENV=test vitest",
    "start": "node --env-file-if-exists=.env index.js",
    "dev": "node --watch --env-file-if-exists=.env index.js | pino-pretty"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goran1010/uniatlas-bosnia.git"
  },
  "type": "module",
  "keywords": [],
  "author": "Goran Jovic",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/goran1010/uniatlas-bosnia/issues"
  },
  "homepage": "https://github.com/goran1010/uniatlas-bosnia#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@quixo3/prisma-session-store": "^3.1.13",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-sync": "^4.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "resend": "^6.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "prettier": "3.6.2",
    "prisma": "^7.3.0",
    "supertest": "^7.1.4",
    "vitest": "^4.1.2"
  }
